  "NestForge Guard (Macro)": {
    "prefix": "nf-guard",
    "description": "Create a guard using the guard! macro with inline logic.",
    "body": [
      "use nestforge::guard;",
      "",
      "guard!(${1:AuthGuard} |ctx| {",
      "    if ctx.is_authenticated() {",
      "        Ok(())",
      "    } else {",
      "        Err(nestforge::HttpException::unauthorized(\"Authentication required\"))",
      "    }",
      "});"
    ]
  },
  "NestForge Auth Guard": {
