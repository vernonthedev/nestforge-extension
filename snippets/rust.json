  "NestForge Injectable with Factory": {
    "prefix": "nf-injectable-factory",
    "description": "Create an injectable service with custom factory initialization.",
    "body": [
      "use nestforge::{injectable, ConfigModule, ConfigOptions};",
      "",
      "/// ${1:Service with custom factory for external configuration.}",
      "#[injectable(factory = ${2:build_config})]",
      "pub struct ${3:AppConfig} {",
      "    pub app_name: String,",
      "}",
      "",
      "fn ${2:build_config}() -> anyhow::Result<${3:AppConfig}> {",
      "    Ok(ConfigModule::for_root::<${3:AppConfig}>(",
      "        ConfigOptions::new().env_file(\".env\"),",
      "    )?)",
      "}"
    ]
  },
