{
  "name": "nestforge",
  "displayName": "NestForge",
  "description": "VS Code extension for NestForge CLI scaffolding, generators, database workflows, and Rust utility commands.",
  "version": "0.1.1",
  "author": "vernonthedev",
  "license": "MIT",
  "packageManager": "pnpm@10.30.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/vernonthedev/nestforge-extension.git"
  },
  "homepage": "https://github.com/vernonthedev/nestforge-extension#readme",
  "bugs": {
    "url": "https://github.com/vernonthedev/nestforge-extension/issues"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nestforge.new",
        "title": "New Application",
        "category": "NestForge"
      },
      {
        "command": "nestforge.generate",
        "title": "Generate",
        "category": "NestForge"
      },
      {
        "command": "nestforge.generateResourceHere",
        "title": "Generate Here",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createModule",
        "title": "Create Module",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createService",
        "title": "Create Service",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createResource",
        "title": "Create Resource",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createController",
        "title": "Create Controller",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createResolver",
        "title": "Create Resolver",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createGateway",
        "title": "Create Gateway",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createGuard",
        "title": "Create Guard",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createInterceptor",
        "title": "Create Interceptor",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createFilter",
        "title": "Create Filter",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createPipe",
        "title": "Create Pipe",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createMiddleware",
        "title": "Create Middleware",
        "category": "NestForge"
      },
      {
        "command": "nestforge.createDecorator",
        "title": "Create Decorator",
        "category": "NestForge"
      },
      {
        "command": "nestforge.dbInit",
        "title": "Init",
        "category": "NestForge DB"
      },
      {
        "command": "nestforge.dbGenerate",
        "title": "Generate",
        "category": "NestForge DB"
      },
      {
        "command": "nestforge.dbMigrate",
        "title": "Migrate",
        "category": "NestForge DB"
      },
      {
        "command": "nestforge.dbStatus",
        "title": "Status",
        "category": "NestForge DB"
      },
      {
        "command": "nestforge.docs",
        "title": "OpenAPI Docs",
        "category": "NestForge"
      },
      {
        "command": "nestforge.formatRust",
        "title": "Format Rust",
        "category": "NestForge"
      },
      {
        "command": "nestforge.openLogs",
        "title": "Open Logs",
        "category": "NestForge"
      },
      {
        "command": "nestforge.onboarding.openDocs",
        "title": "Open Extension Docs",
        "category": "NestForge"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "nestforge.generateResourceHere",
          "when": "explorerResourceIsFolder",
          "group": "NestForge@1"
        },
        {
          "command": "nestforge.generate",
          "when": "explorerResourceIsFolder",
          "group": "NestForge@2"
        }
      ]
    },
    "configuration": {
      "title": "NestForge",
      "properties": {
        "nestforge.cliPath": {
          "type": "string",
          "default": "nestforge",
          "description": "Executable used for NestForge CLI commands."
        },
        "nestforge.cargoPath": {
          "type": "string",
          "default": "cargo",
          "description": "Executable used for cargo utility commands."
        },
        "nestforge.docsUrl": {
          "type": "string",
          "default": "http://localhost:3000/api/docs",
          "description": "Default URL opened by the OpenAPI docs command."
        },
        "nestforge.dbStatus.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show database drift status in the status bar."
        },
        "nestforge.dbStatus.intervalMs": {
          "type": "number",
          "default": 300000,
          "minimum": 60000,
          "description": "Polling interval in milliseconds for database status checks."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "nestforge.gettingStarted",
        "title": "NestForge",
        "description": "Bootstrap a NestForge workspace, generate resources, and manage database drift from VS Code.",
        "steps": [
          {
            "id": "nestforge.gettingStarted.new",
            "title": "Create a project",
            "description": "Launch the `NestForge: New Application` wizard to scaffold a workspace with selected transports.",
            "media": {
              "markdown": "Run [NestForge: New Application](command:nestforge.new) to scaffold a backend."
            }
          },
          {
            "id": "nestforge.gettingStarted.generate",
            "title": "Generate a feature",
            "description": "Use the generator wizard or the Explorer context menu to create and wire resources.",
            "media": {
              "markdown": "Run [NestForge: Generate](command:nestforge.generate) or right-click a folder and choose `Generate Here`."
            }
          },
          {
            "id": "nestforge.gettingStarted.db",
            "title": "Check database status",
            "description": "Inspect migration drift and run database operations from the `NestForge DB` command group.",
            "media": {
              "markdown": "Run [NestForge DB: Status](command:nestforge.dbStatus) to refresh the status bar state."
            }
          },
          {
            "id": "nestforge.gettingStarted.docs",
            "title": "Open project docs",
            "description": "Open the configured OpenAPI endpoint or the extension README.",
            "media": {
              "markdown": "Run [NestForge: OpenAPI Docs](command:nestforge.docs) or [Open Extension Docs](command:nestforge.onboarding.openDocs)."
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "prepare": "lefthook install",
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "build:test": "pnpm run compile-tests && pnpm run compile",
    "pretest": "pnpm run build:test && pnpm run lint",
    "lint": "eslint src",
    "lint:staged": "eslint --max-warnings=0 --fix",
    "test:unit": "node out/test/nestforge-core.test.js",
    "test:hook": "pnpm run build:test && pnpm run test:unit",
    "test": "pnpm run test:unit"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "lefthook": "^2.1.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
